# ─── Required ────────────────────────────────────────────────────────────────

# OpenRouter API key — used for the AI agent (GPT-4o-mini)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# fal.ai key — used for Virtual Try-On (Nano Banana 2)
# Get one at https://fal.ai/dashboard/keys
FAL_KEY=

# ─── Optional — enables user accounts, orders & conversation history ──────────

# MongoDB connection URI
# Works with MongoDB Atlas (free tier) or any MongoDB 6+ instance
# Without this, the app runs fully in static mode (no user accounts, no order history)
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/westside?retryWrites=true&w=majority

# ─── Secrets — change before deploying publicly ───────────────────────────────

# Admin panel session secret (signs the httpOnly cookie)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ADMIN_SECRET=change-me-to-a-long-random-string

# Shopper session secret (signs user login cookies — different from admin)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# USER_JWT_SECRET=change-me-to-another-long-random-string

# Admin credentials (defaults: admin / westside2024 — change before going public)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=westside2024

# ─── Production only ──────────────────────────────────────────────────────────

# Your deployed URL — used as the HTTP-Referer header for OpenRouter requests
# Leave blank for local dev (defaults to http://localhost:3000)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
